# ============================================
# Variables de Entorno - Sistema Cobro Coactivo
# ============================================

# === Docker / Coolify ===
# IMPORTANTE: NEXT_PUBLIC_* son BUILD-TIME (se incrustan en el bundle).
# Si cambias estas variables, DEBES reconstruir la imagen Docker.
# Las variables sin NEXT_PUBLIC_ son RUNTIME (se leen en cada request).

# NextAuth (Auth.js)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=<GENERAR_CON_COMANDO_ARRIBA>

# Azure AD (Office 365) - App multi-tenant propia (patron vTiger)
# Requerido: client_id y client_secret de tu app registration en Entra ID.
AUTH_AZURE_AD_ID=<TU_AZURE_CLIENT_ID>
AUTH_AZURE_AD_SECRET=<TU_AZURE_CLIENT_SECRET>
# Opcional: default "organizations" (cualquier cuenta work/school).
# Alternativas: "common" (work/school + personales) o un tenant ID especifico (single-tenant).
AUTH_AZURE_AD_TENANT_ID=organizations
# Opcional: lista de dominios permitidos (comma-separated).
# Vacio = permitir todos y delegar el control al cruce con la tabla usuarios.
AUTH_AZURE_AD_DOMAIN=cendoj.ramajudicial.gov.co
# Opcional: auto-crear usuario en BD si no existe y el dominio esta permitido.
# false (default) = solo entran usuarios ya registrados (patron vTiger estricto).
AUTH_AZURE_AD_AUTO_CREATE=false
# Publico: mostrar/ocultar el boton de Office 365 en el login.
NEXT_PUBLIC_AZURE_AD_ENABLED=true

# Supabase - BUILD-TIME (requieren rebuild al cambiar)
NEXT_PUBLIC_SUPABASE_URL=<URL_DE_TU_PROYECTO_SUPABASE>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<TU_SUPABASE_ANON_KEY>
# Supabase - RUNTIME (se lee en cada request, no requiere rebuild)
SUPABASE_SERVICE_ROLE_KEY=<TU_SUPABASE_SERVICE_ROLE_KEY>

# Aplicacion - BUILD-TIME
# En Coolify: usar la URL real de produccion (https://cobros.tudominio.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Coolify Environment Variables ===
# Configura estas mismas variables en Coolify > Tu Servicio > Environment Variables.
# Coolify las inyecta en el contenedor en tiempo de ejecucion.
# NOTA: NEXT_PUBLIC_* se leen durante `next build`, por lo que DEBES
# reconstruir la imagen si cambian (Coolify permite redeploy con rebuild).
